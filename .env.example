# Postgres connection string for the feedback/data-annotation database.
# Local dev: run `docker compose up -d` then use the value below.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/fitmind_landing?schema=public"

# Base URL of the FitMind backend API (must have this site's origin in its
# CORS_ALLOWED_ORIGINS — see Backend/.env.example).
NEXT_PUBLIC_API_BASE_URL="http://localhost:8000/v1"
